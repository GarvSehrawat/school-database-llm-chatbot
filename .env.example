APP_NAME=School Database LLM Chatbot
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./school.db
SQL_ECHO=false


# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=

# LLM behavior
LLM_ENABLED=false
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2